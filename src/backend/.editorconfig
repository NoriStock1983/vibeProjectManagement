root = true

[*.cs]

# ===== フォーマット =====
indent_style = space
indent_size = 4
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true
max_line_length = 120

# 波括弧は常に新しい行（Allman スタイル）
csharp_new_line_before_open_brace = all
csharp_new_line_before_else = true
csharp_new_line_before_catch = true
csharp_new_line_before_finally = true

# using ディレクティブ：名前空間の外・System 系を先頭に
csharp_using_directive_placement = outside_namespace:warning
dotnet_sort_system_directives_first = true
dotnet_separate_import_directive_groups = true

# ===== this. 修飾子（不要な this. を禁止）=====
dotnet_style_qualification_for_field = false:warning
dotnet_style_qualification_for_property = false:warning
dotnet_style_qualification_for_method = false:warning
dotnet_style_qualification_for_event = false:warning

# ===== 型エイリアス（string / int など組み込み型を優先）=====
dotnet_style_predefined_type_for_locals_parameters_members = true:warning
dotnet_style_predefined_type_for_member_access = true:warning

# ===== var の使い方 =====
# 型が自明な場合は var を使う
csharp_style_var_for_built_in_types = false:suggestion
csharp_style_var_when_type_is_apparent = true:suggestion
csharp_style_var_elsewhere = false:suggestion

# ===== null 安全 =====
dotnet_style_null_propagation = true:warning
dotnet_style_coalesce_expression = true:warning
csharp_style_throw_expression = true:suggestion
csharp_style_conditional_delegate_call = true:suggestion

# ===== 式スタイル =====
csharp_style_expression_bodied_properties = true:suggestion
csharp_style_expression_bodied_methods = when_on_single_line:suggestion
csharp_style_expression_bodied_constructors = false:silent

# ===== 非同期処理 =====
# async void を避ける（イベントハンドラー除く）
dotnet_diagnostic.CA2008.severity = warning   # TaskScheduler を指定しない Task.Factory.StartNew
dotnet_diagnostic.CA2007.severity = none      # ConfigureAwait（アプリコードでは不要）

# ===== 例外処理 =====
dotnet_diagnostic.CA2200.severity = error     # throw ex; でスタックトレースをリセット禁止

# ===== 命名規則 =====

## 定数フィールド（const）→ PascalCase（private でも同様）
dotnet_naming_rule.const_fields_pascal_case.symbols  = const_fields
dotnet_naming_rule.const_fields_pascal_case.style    = pascal_case_style
dotnet_naming_rule.const_fields_pascal_case.severity = warning

dotnet_naming_symbols.const_fields.applicable_kinds      = field
dotnet_naming_symbols.const_fields.applicable_accessibilities = *
dotnet_naming_symbols.const_fields.required_modifiers    = const

## private フィールド（const 以外）→ _camelCase
dotnet_naming_rule.private_fields_underscore_camel.symbols  = private_fields
dotnet_naming_rule.private_fields_underscore_camel.style    = underscore_camel_case_style
dotnet_naming_rule.private_fields_underscore_camel.severity = warning

dotnet_naming_symbols.private_fields.applicable_kinds            = field
dotnet_naming_symbols.private_fields.applicable_accessibilities  = private

dotnet_naming_style.underscore_camel_case_style.required_prefix = _
dotnet_naming_style.underscore_camel_case_style.capitalization   = camel_case

## インターフェース → I プレフィックス + PascalCase
dotnet_naming_rule.interfaces_must_start_with_i.symbols  = interfaces
dotnet_naming_rule.interfaces_must_start_with_i.style    = interface_prefix_style
dotnet_naming_rule.interfaces_must_start_with_i.severity = error

dotnet_naming_symbols.interfaces.applicable_kinds = interface

dotnet_naming_style.interface_prefix_style.required_prefix = I
dotnet_naming_style.interface_prefix_style.capitalization   = pascal_case

## 非同期メソッド → Async サフィックス
dotnet_naming_rule.async_methods_must_end_with_async.symbols  = async_methods
dotnet_naming_rule.async_methods_must_end_with_async.style    = async_suffix_style
dotnet_naming_rule.async_methods_must_end_with_async.severity = warning

dotnet_naming_symbols.async_methods.applicable_kinds = method
dotnet_naming_symbols.async_methods.required_modifiers = async

dotnet_naming_style.async_suffix_style.required_suffix = Async
dotnet_naming_style.async_suffix_style.capitalization   = pascal_case

## クラス・メソッド・プロパティ・定数 → PascalCase
dotnet_naming_rule.pascal_case_types.symbols  = types_and_members
dotnet_naming_rule.pascal_case_types.style    = pascal_case_style
dotnet_naming_rule.pascal_case_types.severity = warning

dotnet_naming_symbols.types_and_members.applicable_kinds            = class,struct,enum,delegate,method,property,event
dotnet_naming_symbols.types_and_members.applicable_accessibilities  = *

dotnet_naming_style.pascal_case_style.capitalization = pascal_case

# ===== StyleCop 競合ルール無効化 =====
dotnet_diagnostic.SA1309.severity = none   # フィールドに _ 始まりを禁止 → _camelCase を許可するため無効化
dotnet_diagnostic.SA1310.severity = none   # フィールド名にアンダースコアを含めない → 同上
dotnet_diagnostic.SA1101.severity = none   # this. 必須 → dotnet_style_qualification_for_field=false と競合するため無効化
dotnet_diagnostic.SA1200.severity = none   # using を名前空間の中に書く → outside_namespace と競合するため無効化

# ===== XML ドキュメントコメント（public / protected 必須）=====
dotnet_diagnostic.SA1600.severity = warning   # public メンバーに XML コメント必須
dotnet_diagnostic.SA1601.severity = warning   # partial class に XML コメント必須
dotnet_diagnostic.SA1602.severity = warning   # 列挙値に XML コメント必須
dotnet_diagnostic.SA1633.severity = none      # ファイルヘッダー（不要）

# ===== using の順序（StyleCop）=====
dotnet_diagnostic.SA1210.severity = warning   # using をアルファベット順に
dotnet_diagnostic.SA1208.severity = warning   # System.* を先頭に

# ===== その他の静的解析 =====
dotnet_diagnostic.CA1822.severity = suggestion  # static にできるメソッド
dotnet_diagnostic.IDE0055.severity = warning    # フォーマット違反
dotnet_diagnostic.IDE0005.severity = warning    # 不要な using
dotnet_diagnostic.CA1816.severity = warning     # Dispose の実装パターン
